# Frontend Environment Variables
# Copy this file to .env and fill in the values for your environment.

# The base URL of the backend API.
# For local development, this is typically http://127.0.0.1:8000/api
# For production, this should be the URL of your deployed backend API
# (e.g., https://your-backend.up.railway.app/api)
VITE_API_URL=web-production-4cafe.up.railway.app/api
